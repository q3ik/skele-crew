# Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# Social Media MCP Server
# See mcp/social-media-server/README.md for setup instructions per platform
# ---------------------------------------------------------------------------

# dev.to
# Obtain at: https://dev.to/settings/account (DEV API Keys section)
DEVTO_API_KEY=your_devto_api_key_here

# Bluesky (AT Protocol)
# Use an APP PASSWORD, not your main account password.
# Create one at: https://bsky.app/settings/app-passwords
BSKY_IDENTIFIER=yourhandle.bsky.social
BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Mastodon
# Recommended instance for dev/tech: fosstodon.org
# Create an app at: https://<instance>/settings/applications
MASTODON_INSTANCE_URL=https://fosstodon.org
MASTODON_ACCESS_TOKEN=your_mastodon_access_token_here

# Reddit (OAuth2 script app)
# Create an app at: https://www.reddit.com/prefs/apps (select "script" type)
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USERNAME=your_reddit_username_here
REDDIT_PASSWORD=your_reddit_password_here

# ---------------------------------------------------------------------------
# Memory MCP Server
# ---------------------------------------------------------------------------

# Optional: override the default knowledge graph path
# Default: <repo-root>/memory/knowledge-graph.jsonl
# MEMORY_FILE_PATH=memory/knowledge-graph.jsonl
